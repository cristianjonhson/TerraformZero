{
  "servers": {
    "terraform": {
      "name": "Terraform MCP Server",
      "type": "stdio",
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-v",
        "${workspaceFolder}:/workspace",
        "-w",
        "/workspace",
        "-e",
        "MCP_LOG_LEVEL=info",
        "-e",
        "PROJECT_ROOT=/workspace",
        "hashicorp/terraform-mcp-server",
        "--toolset=registry.terraform.io/hashicorp/terraform:1.5.0",
        "stdio"
      ]
    }
  }
}
