{
  "servers": {
    "terraform-local": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-v",
        "${workspaceFolder}:/workspace",
        "-w",
        "/workspace",
        "-e",
        "MCP_LOG_LEVEL=warn",
        "-e",
        "PROJECT_ROOT=/workspace",
        "hashicorp/terraform-mcp-server",
        "--toolsets=registry",
        "stdio"
      ]
    }
  }
}
