# macOS
.DS_Store

# Terraform working directory
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config files
.terraformrc
terraform.rc

# Variable definition files (often contain secrets)
*.tfvars
*.tfvars.json
!*.tfvars.example

# Local generated artifacts
infra/generated/
